generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

model User {
  id                   String              @id @default(cuid())
  name                 String
  email                String              @unique
  emailVerified        DateTime?
  image                String?
  phone                String?
  businessName         String?
  businessDescription  String?
  businessLogo         String?
  supportEmail         String?
  supportPhone         String?
  businessAddress      String?
  notifyOrderReceived  Boolean             @default(true)
  notifyPaymentSuccess Boolean             @default(true)
  notifyWelcome        Boolean             @default(true)
  notifyProductUpdates Boolean             @default(true)
  notifyMarketing      Boolean             @default(false)
  currency             String              @default("NGN")
  timeZone             String              @default("Africa/Lagos")
  dateFormat           String              @default("DD/MM/YYYY")
  passwordHash         String?
  isOnboarded          Boolean             @default(false)
  createdAt            DateTime            @default(now())
  products             Product[]
  resetTokens          PasswordResetToken[]
  accounts             Account[]
  sessions             Session[]
}

model PasswordResetToken {
  id        String   @id @default(cuid())
  email     String
  token     String   @unique
  expiresAt DateTime
  createdAt DateTime @default(now())
  usedAt    DateTime?
  user      User     @relation(fields: [email], references: [email])
}

model Product {
  id          String   @id @default(cuid())
  userId      String
  name        String
  description String?
  price       Float
  imageUrl    String?
  uniqueSlug  String   @unique
  createdAt   DateTime @default(now())
  orders      Order[]
  user        User     @relation(fields: [userId], references: [id])
}

model Order {
  id                   String   @id @default(cuid())
  productId            String
  buyerEmail           String?
  amount               Float
  status               String   @default("PENDING")
  transactionReference String   @unique
  createdAt            DateTime @default(now())
  product              Product  @relation(fields: [productId], references: [id])
  payment              Payment?
}

model Payment {
  id               String    @id @default(cuid())
  orderId          String    @unique
  gatewayReference String    @unique
  status           String
  paidAt           DateTime?
  order            Order     @relation(fields: [orderId], references: [id])
}

model Account {
  id                 String  @id @default(cuid())
  userId             String
  type               String
  provider           String
  providerAccountId  String
  refresh_token      String?
  access_token       String?
  expires_at         Int?
  token_type         String?
  scope              String?
  id_token           String?
  session_state      String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
}

model SupportTicket {
  id        String   @id @default(cuid())
  name      String
  email     String
  subject   String
  message   String
  status    String   @default("OPEN")
  createdAt DateTime @default(now())
}
